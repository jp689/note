# ============================================================
# AI Study Notes — 环境变量配置模板
# ============================================================
# 复制本文件为 .env 并根据实际环境修改。
# 生产环境 (API_ENV=production) 启动时会校验安全配置，
# 默认弱密码/密钥将被拒绝并报错退出。
# ============================================================

# --- Docker Compose / CI-CD ---
# 本地开发可使用默认值；生产环境必须替换为强密码。
POSTGRES_DB=ai_study_notes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# 生产部署时由 GitHub Actions / ECS 使用。
ACR_REGISTRY=registry.cn-hongkong.aliyuncs.com
ACR_NAMESPACE=your-acr-namespace
IMAGE_TAG=latest

# --- 前端 ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://api:8000

# --- 后端 API ---
API_APP_NAME=AI Study Notes API
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ⚠️ 生产环境必须替换为 ≥32 位随机字符串，禁止使用 change-me
API_SECRET_KEY=change-me

API_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_study_notes
API_REDIS_URL=redis://redis:6379/0
API_S3_ENDPOINT=http://minio:9000
API_S3_BUCKET=study-notes
API_S3_ACCESS_KEY=minioadmin
API_S3_SECRET_KEY=minioadmin

# --- OpenAI 配置（可选）---
# 留空时系统自动使用确定性回退模式（SHA-256 嵌入），
# 不会调用外部 AI 服务。如需真实 AI 能力，请填入有效密钥。
API_OPENAI_BASE_URL=https://api.openai.com/v1
API_OPENAI_API_KEY=

# --- DeepSeek/阿里云百炼配置（可选）---
# 使用阿里云百炼平台的 DeepSeek 模型生成知识节点、思维导图和测验题目。
# 留空时系统将使用模板化回退模式。
API_DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
API_DEEPSEEK_API_KEY=
API_DEEPSEEK_MODEL=deepseek-v3

# --- 通用 OpenAI-compatible 文本模型别名（可选）---
# 后端也支持使用这组变量覆盖 API_DEEPSEEK_*。
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_ID=

# --- PaddleOCR 配置（可选）---
# 留空时系统将跳过 OCR，使用内置回退模式。
API_PADDLEOCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
API_PADDLEOCR_TOKEN=
API_PADDLEOCR_MODEL=PaddleOCR-VL-1.5
OCR_ACCESS_TOKEN=

API_PROCESS_INLINE=false
API_SEED_DEMO=true
API_AUTO_CREATE_TABLES=true
API_MAX_UPLOAD_BYTES=31457280
API_WORKER_REDIS_QUEUE=study-documents

# ⚠️ 生产环境必须替换为 ≥32 位随机字符串，禁止使用 dev-worker-token
API_WORKER_INTERNAL_TOKEN=dev-worker-token

API_LOCAL_STORAGE_DIR=.local/storage

# --- Worker ---
REDIS_URL=redis://redis:6379/0
WORKER_REDIS_QUEUE=study-documents
WORKER_POLL_SECONDS=3
WORKER_API_BASE_URL=http://api:8000

# ⚠️ 生产环境必须替换为 ≥32 位随机字符串，禁止使用 dev-worker-token
WORKER_INTERNAL_TOKEN=dev-worker-token

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
